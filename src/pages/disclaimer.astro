          <p>Users are solely responsible for any comments posted. NETSums reserves the right to delete any comment at any time.</p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Professional Advice</h2>
          <p>Content on this Service is not a substitute for professional legal, accounting, or tax consultation.</p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Contact</h2>
          <p>
            <a href="mailto:contact@netsums.com" style="color:#5ce1e6">contact@netsums.com</a>
            {' '}or via the{' '}
            <a href="/contact" style="color:#5ce1e6">contact form</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
