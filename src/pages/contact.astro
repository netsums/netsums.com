---
import Layout from '../layouts/Layout.astro';
// Get a free access key at https://web3forms.com (enter contact@netsums.com).
// The key is public/safe to expose in client-side code.
const WEB3FORMS_ACCESS_KEY = '32e6372d-7cb0-44ff-b110-8626426ffd21';
---

<Layout title="Contact" description="Get in touch with NETSums.">
  <section class="py-20 px-4">
    <div class="max-w-xl mx-auto">
      <div class="mb-10">
        <span class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-4 border" style="color:#5ce1e6; border-color:#03989e44; background:#03989e1a">
          Get in Touch
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white">Contact</h1>
        <p class="mt-3" style="color:#94a3b8">Fill out the form and I'll get back to you as soon as possible.</p>
      </div>

      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="rounded-xl border border-white/10 p-8 flex flex-col gap-5"
        style="background-color:#132d52"
      >
        <!-- Web3Forms config -->
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="New message from netsums.com contact form" />
        <input type="hidden" name="from_name" value="NETSums Website" />
        <!-- Honeypot spam trap (bots fill this; humans don't see it) -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="flex flex-col gap-1">
          <label for="name" class="text-sm font-medium text-white">Your Name <span style="color:#03989e">*</span></label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="John Doe"
            class="rounded-lg px-4 py-2.5 text-white text-sm outline-none border focus:border-[#03989e] transition-colors"
            style="background:#0f2240; border-color:#ffffff22; color:#e2e8f0"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label for="email" class="text-sm font-medium text-white">Email Address <span style="color:#03989e">*</span></label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="rounded-lg px-4 py-2.5 text-sm outline-none border focus:border-[#03989e] transition-colors"
            style="background:#0f2240; border-color:#ffffff22; color:#e2e8f0"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label for="message" class="text-sm font-medium text-white">Your Message <span style="color:#03989e">*</span></label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="How can I help you?"
            class="rounded-lg px-4 py-2.5 text-sm outline-none border focus:border-[#03989e] transition-colors resize-none"
            style="background:#0f2240; border-color:#ffffff22; color:#e2e8f0"
          ></textarea>
        </div>

        <label class="flex items-start gap-2 text-sm" style="color:#94a3b8">
          <input type="checkbox" required class="mt-1 accent-[#03989e]" />
          <span>I agree that my data will be processed to handle my request, as described in the
            <a href="/privacy-policy" class="underline" style="color:#5ce1e6">Privacy Policy</a>.</span>
        </label>

        <button
          id="submit-btn"
          type="submit"
          class="mt-2 px-6 py-3 rounded-lg font-semibold text-white transition-opacity hover:opacity-90 disabled:opacity-60"
          style="background-color:#03989e"
        >
          Send Message
        </button>

        <p id="form-status" class="text-sm hidden"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const status = document.getElementById('form-status') as HTMLParagraphElement;

    function setStatus(msg: string, ok: boolean) {
      status.textContent = msg;
      status.classList.remove('hidden');
      status.style.color = ok ? '#5ce1e6' : '#f87171';
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = 'Sending…';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          setStatus('Thanks! Your message has been sent — I\'ll get back to you soon.', true);
        } else {
          setStatus(data.message || 'Something went wrong. Please try again or email contact@netsums.com.', false);
        }
      } catch {
        setStatus('Network error. Please try again or email contact@netsums.com.', false);
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  </script>
</Layout>
