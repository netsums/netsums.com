---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy" description="Privacy Policy for NETSums.">
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-extrabold text-white mb-2">Privacy Policy</h1>
      <p class="text-sm mb-8" style="color:#94a3b8">Last updated: January 11, 2023</p>

      <div class="rounded-xl border border-white/10 p-8 flex flex-col gap-6" style="background-color:#132d52; color:#94a3b8">
        <p>This Privacy Policy describes how NETSums collects, uses, and discloses your information when you use this Service, and explains your privacy rights.</p>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Company Information</h2>
          <p>Ricardo Carvalho, c/o Block Services, Stuttgarter Str. 106, 70736 Fellbach, Germany</p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Data We Collect</h2>
          <ul class="list-disc list-inside space-y-1">
            <li><strong class="text-white">Personal Data:</strong> email address, first and last name</li>
            <li><strong class="text-white">Usage Data:</strong> IP addresses, browser type/version, pages visited, visit duration, device identifiers</li>
            <li><strong class="text-white">Tracking Technologies:</strong> Session and Persistent Cookies, Web Beacons</li>
          </ul>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">How We Use Your Data</h2>
          <p>To provide and improve the Service, manage your account, communicate with you, send promotional offers (with your consent), and for analytics.</p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Children's Privacy</h2>
          <p>This Service does not address users under 13 years of age. We do not knowingly collect personal data from children under 13.</p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-white mb-2">Contact</h2>
          <p>
            <a href="mailto:contact@netsums.com" style="color:#5ce1e6">contact@netsums.com</a>
            {' '}or via the{' '}
            <a href="/contact" style="color:#5ce1e6">contact form</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
