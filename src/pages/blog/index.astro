---
import Layout from '../../layouts/Layout.astro';

// To add a blog post, create a .md file in src/content/blog/
// Example: src/content/blog/my-first-post.md
// Then add it to this array:
const posts: { title: string; date: string; slug: string; excerpt: string }[] = [
  // { title: 'My First Post', date: '2025-01-01', slug: 'my-first-post', excerpt: 'Short summary...' },
];
---

<Layout title="Blog" description="Articles and insights from NETSums on IT security and networking.">
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12">
        <span class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-4 border" style="color:#5ce1e6; border-color:#03989e44; background:#03989e1a">
          NETSums Blog
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white">Blog</h1>
        <p class="mt-3 text-lg" style="color:#94a3b8">Articles, tips, and deep dives on IT security and networking.</p>
      </div>

      {posts.length === 0 ? (
        <div class="rounded-xl border border-white/10 p-12 text-center" style="background-color:#132d52">
          <svg class="h-12 w-12 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#03989e">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
          <h2 class="text-lg font-semibold text-white mb-2">Coming soon</h2>
          <p style="color:#94a3b8">No posts yet — check back soon or subscribe on YouTube for the latest content.</p>
          <a
            href="https://www.youtube.com/channel/UCCBxPV1V0majbAR5PNu2ACw/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-6 px-5 py-2.5 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90"
            style="background-color:#03989e"
          >
            Subscribe on YouTube
          </a>
        </div>
      ) : (
        <div class="flex flex-col gap-6">
          {posts.map(post => (
            <article class="rounded-xl border border-white/10 p-6 hover:-translate-y-0.5 transition-transform" style="background-color:#132d52">
              <time class="text-xs font-medium" style="color:#03989e">{post.date}</time>
              <h2 class="mt-1 text-xl font-bold text-white">
                <a href={`/blog/${post.slug}`} class="hover:text-[#5ce1e6] transition-colors">{post.title}</a>
              </h2>
              <p class="mt-2 text-sm" style="color:#94a3b8">{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="mt-4 inline-block text-sm font-medium hover:underline" style="color:#5ce1e6">
                Read more →
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
